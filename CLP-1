CREATE TABLE EMPLOYEE (
    EmpId INT PRIMARY KEY,
    EmpName VARCHAR(100) NOT NULL,
    DeptId INT NOT NULL, 
    FOREIGN KEY (DeptId)
    REFERENCES DEPARTMENT(DepartmentId)
);

