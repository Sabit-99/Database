DROP DATABASE CompanyDB;
CREATE DATABASE CompanyDB;
USE CompanyDB;

CREATE TABLE COUNTRY (
    CountryId INT PRIMARY KEY,
    CountryName VARCHAR(100) NOT NULL UNIQUE,
    Continent VARCHAR(100) NOT NULL,
    Currency VARCHAR(50) NOT NULL
);

