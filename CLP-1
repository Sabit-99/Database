CREATE TABLE DEPARTMENT (
    DepartmentId INT PRIMARY KEY,
    DeptName VARCHAR(100) NOT NULL,
    CountryId INT NOT NULL,
    
    FOREIGN KEY (CountryId)
    REFERENCES COUNTRY(CountryId)
);
