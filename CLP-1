CREATE TABLE FOLDER (
    FolderId INT PRIMARY KEY,
    EmpId INT NOT NULL,
    AccessType ENUM('Read','Write','Admin') NOT NULL,  
    FOREIGN KEY (EmpId)
    REFERENCES EMPLOYEE(EmpId)
);

